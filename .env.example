# ══════════════════════════════════════════════════════════════════════════════
# STEP 1 — Fill in the values below, then run:  node scripts/setup.js
#
# These are the only values you need to provide manually.
# Everything else (auth servers, OAuth clients, AI agents, private keys)
# is provisioned automatically by the setup script.
# ══════════════════════════════════════════════════════════════════════════════

# ── Okta Org ─────────────────────────────────────────────────────────────────
# Your Okta org domain — find in Okta Admin → Dashboard (top-right corner)
# e.g. dev-12345678.okta.com  (no https://, no trailing slash)
OKTA_DOMAIN=

# Authorization Server ID — used by P4 for STS token exchange.
# The built-in "default" server works fine here.
# Find at: Okta Admin → Security → API → Authorization Servers → "default" → Settings
# e.g. default  (or a custom server ID like aus1ab2cd3ef4gh5ij)
OKTA_AUTH_SERVER_ID=

# ── Console / App URLs ────────────────────────────────────────────────────────
# Base URL of this Next.js console — must be reachable from your browser.
# All OAuth redirect URIs are derived from this base (e.g. .../api/auth/callback/p2).
# Default: http://localhost:3020  (change if hosting on a server)
NEXTAUTH_URL=http://localhost:3020

# Standalone Okta MCP Bridge URL (Pattern 1 — 3rd Party Coding Assistant).
# Run the bridge separately on the host before starting P1.
# See Pattern 1 setup guide in the console for instructions.
# Default: http://localhost:8008
MCP_ADAPTER_URL=http://localhost:8008

# ── LLM (at least one required) ──────────────────────────────────────────────
# Claude API key — preferred (console.anthropic.com → API Keys)
# Leave blank to fall back to OpenAI.
ANTHROPIC_API_KEY=

# OpenAI API key — fallback if ANTHROPIC_API_KEY is blank (platform.openai.com)
OPENAI_API_KEY=

# ── Slack (P6 — optional) ────────────────────────────────────────────────────
# Bot token for P6 Autonomous A2A reports. Leave blank to disable Slack posting.
# Create a Slack app at api.slack.com → OAuth scopes: chat:write, chat:write.public, channels:read
# Token format: xoxb-...
SLACK_BOT_TOKEN=

# Slack channel where P6 posts its reports. No # prefix. e.g. demo-reports
SLACK_DEFAULT_CHANNEL=general

# ── Port overrides (optional — change only if defaults conflict) ───────────────
CONSOLE_PORT=3020           # Next.js console
EVENT_BUS_PORT=4000         # SSE event bus
P2_PORT=3200                # P2 agent
P3_PORT=3300                # P3 agent
P4_PORT=3400                # P4 agent
P5_PORT=3500                # P5 agent
P6_PORT=3600                # P6 agent
P7_PORT=3700                # P7 agent

# ── P4: OIN integrations — manual setup required ─────────────────────────────
# These cannot be automated. After running the setup script, follow the
# instructions printed at the end to obtain these ORN values from Okta Admin.
#
# GitHub Enterprise OIN integration ORN:
#   Okta Admin → Applications → Browse App Catalog → GitHub Enterprise
#   Enable STS → copy the resource ORN (starts with orn:okta:...)
P4_GITHUB_STS_RESOURCE=

# Slack OIN integration ORN:
#   Okta Admin → Applications → Browse App Catalog → Slack
#   Enable STS → install with scopes: chat:write, chat:write.public, channels:read → copy ORN
P4_SLACK_STS_RESOURCE=

# ══════════════════════════════════════════════════════════════════════════════
# STEP 2 — Run:  node scripts/setup.js
#
# The script reads your values above, calls Okta APIs, and fills in everything
# below automatically. Do NOT edit the vars below by hand before running.
# ══════════════════════════════════════════════════════════════════════════════

# ── Derived — computed from seed values, no API call ─────────────────────────
NEXT_PUBLIC_OKTA_DOMAIN=           # = OKTA_DOMAIN (browser-exposed for P5 PKCE)
OKTA_ISSUER=                       # = https://${OKTA_DOMAIN}/oauth2/${OKTA_AUTH_SERVER_ID}

# ── MCP Resource Servers — provisioned by setup script ───────────────────────
HR_AUTHZ_SERVER_ID=                # Okta auth server ID for HR MCP server
HR_RESOURCE_AUDIENCE=              # Token audience HR server expects (api:hr)
FINANCE_AUTHZ_SERVER_ID=           # Okta auth server ID for Finance MCP server
FINANCE_RESOURCE_AUDIENCE=         # Token audience Finance server expects (api:finance)
INVENTORY_AUTHZ_SERVER_ID=         # Okta auth server ID for Inventory MCP server
INVENTORY_RESOURCE_AUDIENCE=       # Token audience Inventory server expects (api://inventory-resource)

# ── Pattern 2: 3rd Party Consumer Agent ──────────────────────────────────────
P2_OKTA_CLIENT_ID=                 # OIDC web app client ID
P2_OKTA_CLIENT_SECRET=             # Client secret

# ── Pattern 3: 1st Party XAA Native ─────────────────────────────────────────
P3_OKTA_CLIENT_ID=                 # OIDC web app client ID
P3_OKTA_CLIENT_SECRET=             # Client secret
P3_OKTA_AI_AGENT_ID=               # Workload Principal ID (wlp_xxx)
# Agent's private key — JWK JSON string (single line, no spaces)
P3_OKTA_PRIVATE_KEY=
# SSWS admin token for Okta Connections API (okta.aiAgents.read scope required)
# Auth server IDs and scopes are now loaded dynamically from Okta — HR_AUTHZ_SERVER_ID / FINANCE_AUTHZ_SERVER_ID not needed for P3
OKTA_API_TOKEN=

# ── Pattern 4: Outbound SaaS via Okta STS ────────────────────────────────────
P4_OKTA_CLIENT_ID=                 # OIDC web app client ID
P4_OKTA_CLIENT_SECRET=             # Client secret
P4_OKTA_AI_AGENT_ID=               # Workload Principal ID (wlp_xxx)
# Agent's private key — JWK JSON string (single line, no spaces)
P4_OKTA_PRIVATE_KEY=

# ── Pattern 5: Human-in-the-Loop (CIBA) — not yet built ─────────────────────
P5_OKTA_CLIENT_ID=
P5_OKTA_CLIENT_SECRET=
P5_OKTA_AI_AGENT_ID=
P5_OKTA_PRIVATE_KEY=
P5_CIBA_AUTHZ_SERVER_ID=
P5_CIBA_AUTHENTICATOR_ID=
P5_ANDROID_OKTA_CLIENT_ID=

# ── Pattern 6: Agent-to-Agent (A2A) delegation ───────────────────────────────
# User signs into the console (app) → orchestrator agent acts on the user's behalf
# and delegates to specialized worker agents via Okta A2A. Chain: user id_token →
# orchestrator token-exchange → worker A2A access token (scope agent.invoke,
# act=user→orchestrator) → worker token-exchanges it → HR/Finance resource token →
# MCP. Requires the Beta OKTA_FOR_AI_AGENTS / SECURE_AI_A2A_SERVERS features.
#
# Orchestrator AI Agent identity (signs A2A client assertions; token-exchange grant)
P6_ORCHESTRATOR_OKTA_AI_AGENT_ID=  # Workload Principal ID (wlp_...)
P6_ORCHESTRATOR_OKTA_PRIVATE_KEY=  # JWK JSON string (single line, no spaces)
# Web-app client linked to the orchestrator agent — PKCE sign-on in the console
# (redirect URI http://localhost:3020/api/auth/callback/p6). On the orchestrator's
# Delegations screen, add this as a "User sign-on" caller.
P6_ORCHESTRATOR_OKTA_CLIENT_ID=
P6_ORCHESTRATOR_OKTA_CLIENT_SECRET=
P6_A2A_SCOPE=agent.invoke
# Orchestrator as a resource — needed for Mission 1 (CC/autonomous). The console app
# uses CC grant targeting this resource; orchestrator validates the inbound token.
P6_ORCH_A2A_RESOURCE=              # audience/resource URL on the orchestrator's A2A auth server
P6_ORCH_A2A_AUTHZ_SERVER_ID=       # auth server ID that issues CC tokens to invoke the orchestrator
#
# Per worker — Okta prereqs (SUPER_ADMIN, Beta): (1) publish worker wlp as an A2A
# server resource on an auth server w/ agent.invoke; (2) connection orchestrator→worker
# (IDENTITY_ASSERTION_A2A_SERVER); (3) delegation link orchestrator→worker (ACCESS_TOKEN);
# (4) connection worker→HR/Finance (IDENTITY_ASSERTION_CUSTOM_AS, hr:read/finance:read);
# (5) delegation link worker→HR/Finance resource. Worker downstream reuses HR_/FINANCE_AUTHZ_SERVER_ID.
# HR Worker
P6_HR_WORKER_OKTA_AI_AGENT_ID=     # HR Worker wlp_...
P6_HR_WORKER_PRIVATE_KEY=          # HR Worker JWK (single line) — signs its outbound token-exchange
P6_HR_WORKER_A2A_RESOURCE=         # orn:...:resource-servers:a2a:wlp...  (inbound audience)
P6_HR_WORKER_A2A_AUTHZ_SERVER_ID=  # auth server protecting the HR Worker A2A resource
P6_HR_WORKER_URL=http://p6-hr-worker:3601
# Finance Worker
P6_FINANCE_WORKER_OKTA_AI_AGENT_ID=
P6_FINANCE_WORKER_PRIVATE_KEY=
P6_FINANCE_WORKER_A2A_RESOURCE=
P6_FINANCE_WORKER_A2A_AUTHZ_SERVER_ID=
P6_FINANCE_WORKER_URL=http://p6-finance-worker:3602

# ── Pattern 7: Multi-Tenant FGA — not yet built ──────────────────────────────
OKTA_FGA_STORE_ID=
OKTA_FGA_CLIENT_ID=
OKTA_FGA_CLIENT_SECRET=
P7_RESOURCE_AUDIENCE=api://p7-resource

# ── Theme system ──────────────────────────────────────────────────────────────
# Industry theme for the demo. One of: default | healthcare | retail | manufacturing | government | education
DEMO_THEME=default

# MCP server base URLs — used by the console /api/theme route to hot-swap themes
# In Docker: use service names. In local dev without Docker: use localhost
HR_SERVER_URL=http://hr-server:3101
FINANCE_SERVER_URL=http://finance-server:3102
INVENTORY_SERVER_URL=http://inventory-server:3103
