# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — never commit it.

aws_region       = "us-east-1"
instance_type    = "t3.medium"
key_pair_name    = "okta-demo"
allowed_ssh_cidr = "0.0.0.0/0"
git_repo_url     = "https://github.com/marcopolox/okta-agentic-demo.git"
git_branch       = "main"
git_token        = ""          # GitHub PAT (repo scope) — required for private repos
docker_profiles  = "p3,p4,p6"         # Profiles to activate; comma-separated, no spaces
console_port     = 3020
